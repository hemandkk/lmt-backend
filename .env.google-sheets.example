# Copy relevant keys into your local .env

# Google Sheets — auto-append on lead create
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_WORKSHEET_NAME=Leads
GOOGLE_SERVICE_ACCOUNT_FILE=app/credentials/google-service-account.json
# Or paste JSON inline instead of a file:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SHEETS_MAX_RETRIES=3
GOOGLE_SHEETS_RETRY_BACKOFF_SECONDS=1.5

# Used to build absolute document URLs in the sheet
APP_BASE_URL=http://localhost:8000
